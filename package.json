{
  "name": "instagram-clone",
  "version": "1.0.0",
  "scripts": {
    "install:frontend": "cd frontend && npm install --include=dev",
    "install:backend": "cd backend && npm install --include=dev",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build": "npm run install:frontend && npm run build:frontend && npm run install:backend && npm run build:backend",
    "start": "cd backend && npm start",
    "dev": "cd backend && npm run dev"
  }
}
